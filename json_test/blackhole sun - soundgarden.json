  "lines": [
    {
      "text": "In my eyes, indisposed\n",
      "startTokenIndex": 0,
      "endTokenIndex": 3
    },
    {
      "text": "In disguises no one knows\n",
      "startTokenIndex": 4,
      "endTokenIndex": 8
    },
    {
      "text": "As the face lies, the snake\n",
      "startTokenIndex": 9,
      "endTokenIndex": 14
    },
    {
      "text": "In the sun, in my disgrace\n\n",
      "startTokenIndex": 15,
      "endTokenIndex": 20
    },
    {
      "text": "Boiling heat, summer stench\n",
      "startTokenIndex": 21,
      "endTokenIndex": 24
    },
    {
      "text": "'Neath the black, the sky looks dead\n",
      "startTokenIndex": 25,
      "endTokenIndex": 31
    },
    {
      "text": "Call my name through the cream\n",
      "startTokenIndex": 32,
      "endTokenIndex": 37
    },
    {
      "text": "And I'll hear you scream again\n\n",
      "startTokenIndex": 38,
      "endTokenIndex": 43
    },
    {
      "text": "Black hole sun, won't you come?\n",
      "startTokenIndex": 44,
      "endTokenIndex": 49
    },
    {
      "text": "Wash away the rain\n",
      "startTokenIndex": 50,
      "endTokenIndex": 53
    },
    {
      "text": "Black hole sun, won't you come?\n",
      "startTokenIndex": 54,
      "endTokenIndex": 59
    },
    {
      "text": "Won't you come, won't you come?\n\n",
      "startTokenIndex": 60,
      "endTokenIndex": 65
    },
    {
      "text": "Stuttering, cold and dead\n",
      "startTokenIndex": 66,
      "endTokenIndex": 69
    },
    {
      "text": "Steal the warm wind, tired friend\n",
      "startTokenIndex": 70,
      "endTokenIndex": 75
    },
    {
      "text": "Times are gone for honest men\n",
      "startTokenIndex": 76,
      "endTokenIndex": 81
    },
    {
      "text": "Sometimes far too long for snakes\n\n",
      "startTokenIndex": 82,
      "endTokenIndex": 87
    },
    {
      "text": "In my shoes, walking sleep\n",
      "startTokenIndex": 88,
      "endTokenIndex": 92
    },
    {
      "text": "In my youth, I pray to keep\n",
      "startTokenIndex": 93,
      "endTokenIndex": 99
    },
    {
      "text": "Heaven sent hell away\n",
      "startTokenIndex": 100,
      "endTokenIndex": 103
    },
    {
      "text": "No one sings like you anymore\n\n",
      "startTokenIndex": 104,
      "endTokenIndex": 109
    },
    {
      "text": "Black hole sun, won't you come?\n",
      "startTokenIndex": 110,
      "endTokenIndex": 115
    },
    {
      "text": "Wash away the rain\n",
      "startTokenIndex": 116,
      "endTokenIndex": 119
    },
    {
      "text": "Black hole sun, won't you come?\n",
      "startTokenIndex": 120,
      "endTokenIndex": 125
    },
    {
      "text": "Won't you come?\n\n",
      "startTokenIndex": 126,
      "endTokenIndex": 128
    },
    {
      "text": "Black hole sun, won't you come?\n",
      "startTokenIndex": 129,
      "endTokenIndex": 134
    },
    {
      "text": "Wash away the rain\n",
      "startTokenIndex": 135,
      "endTokenIndex": 138
    },
    {
      "text": "Black hole sun, won't you come?\n",
      "startTokenIndex": 139,
      "endTokenIndex": 144
    },
    {
      "text": "Won't you come, won't you come?\n",
      "startTokenIndex": 145,
      "endTokenIndex": 150
    },
    {
      "text": "Won't you come, won't you come?\n\n",
      "startTokenIndex": 151,
      "endTokenIndex": 156
    },
    {
      "text": "Hang my head, drown my fear\n",
      "startTokenIndex": 157,
      "endTokenIndex": 162
    },
    {
      "text": "'Til you all just disappear\n\n",
      "startTokenIndex": 163,
      "endTokenIndex": 167
