{
    "name": "karaokebox-lyric-editor",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "main": "electron/main.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "electron:dev": "concurrently \"vite\" \"node server-proxy.js\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
        "clean-start": "powershell -ExecutionPolicy Bypass -File ./scripts/cleanup.ps1 && npm run electron:dev",
        "electron:build": "vite build && electron-builder",
        "electron:pack": "vite build && electron-builder --dir"
    },
    "dependencies": {
        "@distube/ytdl-core": "^4.16.12",
        "autoprefixer": "^10.4.23",
        "better-sqlite3": "^12.5.0",
        "clsx": "^2.1.1",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "fs-extra": "^11.3.3",
        "lucide-react": "^0.562.0",
        "mp4-muxer": "^5.2.2",
        "play-dl": "^1.9.7",
        "postcss": "^8.5.6",
        "prop-types": "^15.8.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "remotion": "^4.0.382",
        "tailwind-merge": "^3.4.0",
        "tailwindcss": "^3.4.17",
        "tailwindcss-animate": "^1.0.7"
    },
    "devDependencies": {
        "@types/react": "^18.2.66",
        "@types/react-dom": "^18.2.22",
        "@vitejs/plugin-react": "^4.2.1",
        "concurrently": "^8.2.0",
        "cross-env": "^7.0.3",
        "electron": "^28.0.0",
        "electron-builder": "^24.6.0",
        "vite": "^5.2.0",
        "wait-on": "^7.0.1"
    },
    "build": {
        "appId": "com.karaokebox.app",
        "productName": "KaraokeBox",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "win": {
            "target": "nsis"
        }
    }
}
